{
  "name": "snapboard",
  "version": "0.1.2",
  "buildStage": "alpha",
  "releaseDate": "2026-02-27",
  "description": "A minimal dock-based kanban board and companion app to SnapDock.",
  "author": {
    "name": "StaxDash Studio",
    "email": "zforddev@gmail.com"
  },
  "private": true,
  "license": "MIT",
  "main": "src/main.js",
  "scripts": {
    "dev": "electron .",
    "build:css": "tailwindcss -i ./src/styles/tailwind.css -o ./src/styles/styles.css --minify",
    "build": "npm run build:css && electron-builder"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZFordDev/SnapBoard.git"
  },
  "bugs": {
    "url": "https://github.com/ZFordDev/SnapBoard/issues"
  },
  "homepage": "https://github.com/ZFordDev/SnapBoard#readme",
  "keywords": [
    "kanban",
    "board",
    "local-first",
    "SnapDock",
    "SnapBoard",
    "productivity"
  ],
  "dependencies": {
    "electron-store": "^9.0.0"
  },
  "devDependencies": {
    "electron": "40.4.0",
    "electron-builder": "^26.7.0",
    "tailwind": "^3.1.0",
    "tailwindcss": "^3.4.17"
  },
  "build": {
    "appId": "studio.staxdash.snapboard",
    "productName": "SnapBoard",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "ZFordDev",
        "repo": "SnapBoard"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "SnapBoard-Setup.exe",
      "icon": "src/assets/icon.ico"
    },
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "category": "Utility",
      "icon": "src/assets/icons"
    },
    "appImage": {
      "artifactName": "SnapBoard.AppImage"
    },
    "deb": {
      "artifactName": "snapboard_${version}_amd64.deb"
    }
  }
}
