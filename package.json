{
  "name": "snapboard",
  "version": "0.2.5",
  "buildStage": "alpha",
  "releaseDate": "2026-05-15",
  "description": "A minimal dock-based kanban board and companion app to SnapDock.",
  "author": {
    "name": "ZFordDev",
    "email": "zforddev@gmail.com"
  },
  "license": "MIT",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:css": "tailwindcss -i ./src/styles/tailwind.css -o ./src/styles/styles.css --minify",
    "bundle": "node bundle.js",
    "build": "npm run build:css && npm run bundle && electron-builder"
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "marked": "^18.0.4"
  },
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^26.7.0",
    "esbuild": "^0.28.0",
    "tailwindcss": "3.4.17"
  },
  "build": {
    "appId": "studio.zforddev.snapboard",
    "productName": "SnapBoard",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "src/preload.js",
      "styles/**/*",
      "src/**/*",
      "index.html",
      "main.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "logo.ico",
      "artifactName": "SnapBoard-Setup.exe"
    },
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "category": "Utility",
      "icon": "logo"
    },
    "appImage": {
      "artifactName": "SnapBoard.AppImage"
    },
    "deb": {
      "artifactName": "snapboard_${version}_amd64.deb"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ZFordDev",
        "repo": "SnapBoard",
        "channel": "alpha"
      }
    ]
  }
}
