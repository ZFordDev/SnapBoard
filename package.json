{
  "name": "snapboard",
  "version": "0.1.4",
  "buildStage": "alpha",
  "releaseDate": "2026-03-09",

  "description": "A minimal dock-based kanban board and companion app to SnapDock.",
  "author": "ZFordDev",
  "license": "MIT",
  "private": true,

  "main": "main.js",

  "scripts": {
    "start": "electron .",
    "build:css": "tailwindcss -i ./src/styles/tailwind.css -o ./src/styles/styles.css --minify",
    "bundle": "node bundle.js",
    "build": "npm run build:css && npm run bundle && electron-builder"
  },

  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "6.7.3",
    "marked": "^12.0.0"
  },

  "devDependencies": {
    "electron": "^40.7.0",
    "electron-builder": "^26.7.0",
    "esbuild": "^0.27.3",
    "tailwindcss": "^3.4.17"
  },

  "build": {
  "appId": "studio.zforddev.snapboard",
  "productName": "SnapBoard",

  "directories": {
    "output": "dist",
    "buildResources": "assets"
  },

  "files": [
    "dist/**/*",
    "src/preload.js",
    "styles/**/*",
    "src/**/*",
    "index.html",
    "main.js",
    "package.json"
  ],

  "extraResources": [
    {
      "from": "assets/",
      "to": "assets/",
      "filter": ["**/*"]
    }
  ],

  "win": {
    "target": "nsis",
    "icon": "logo.ico",
    "artifactName": "SnapBoard-Setup.exe"
  },

  "linux": {
    "target": ["deb", "AppImage"],
    "category": "Utility",
    "icon": "logo"
  },

  "appImage": {
    "artifactName": "SnapBoard.AppImage"
  },

  "deb": {
    "artifactName": "snapboard_${version}_amd64.deb"
  },

  "publish": [
    {
      "provider": "github",
      "owner": "ZFordDev",
      "repo": "SnapBoard",
      "channel": "alpha"
      }
    ]
  }
}
